        window.location.reload();
    };

    function showPaymentSuccess(threadsAdded, totalAmount) {
        const processingStep = document.getElementById("processingStep");
        const successStep = document.getElementById("successStep");

        console.log("Showing payment success - Threads:", threadsAdded, "Amount:", totalAmount);

        document.getElementById("successThreadsAmount").textContent = threadsAdded;
        document.getElementById("successTotalAmount").textContent = totalAmount;

        // Hide processing, show success
        processingStep.style.display = "none";
        successStep.style.display = "block";

        console.log("Success step now visible");
    }

    function showPaymentError(errorMessage) {
        const modal = document.getElementById("paymentProcessingModal");
        modal.style.display = "none";

        // Show error in purchase modal
        openPurchaseThreadsModal(window.currentThreadsDisplay);
        showError(errorMessage);

        const btn = document.getElementById("confirmPurchaseBtn");
        btn.disabled = false;
        btn.innerHTML = "Confirm Purchase";
    }

    // Close modal on background click
    document.getElementById("purchaseThreadsModal").addEventListener("click", function(e) {
        if (e.target === this) {
            closePurchaseThreadsModal();
        }
    });

    // Prevent closing payment processing modal on background click
    document.getElementById("paymentProcessingModal").addEventListener("click", function(e) {
        if (e.target === this) {
            // Do nothing - prevent closing during payment
            console.log("Attempted to close payment modal - blocked");
        }
    });
</script>