        modal.style.display = "none";
        resetPurchaseForm();
    };

    function resetPurchaseForm() {
        selectedPaymentMethod = null;
        selectedEwallet = null;
        purchaseState = { threads: 0, method: null, ewallet: null };

        document.getElementById("threadsAmount").value = "";
        document.getElementById("ewalletPhoneNumber").value = "";
        document.querySelectorAll(".payment-method-radio").forEach(r => r.checked = false);
        document.querySelectorAll(".payment-method-card").forEach(c => c.classList.remove("selected"));
        document.getElementById("ewalletOptions").classList.remove("active");
        document.getElementById("creditcardForm").classList.remove("active");
        document.getElementById("paymentSummary").style.display = "none";
        document.getElementById("confirmPurchaseBtn").disabled = true;
        document.getElementById("cardholderName").value = "";
        document.getElementById("cardNumber").value = "";
        document.getElementById("cardExpiry").value = "";
        document.getElementById("cardCVV").value = "";
        clearMessages();
    }

    function clearMessages() {
        const errorMsg = document.getElementById("purchaseErrorMessage");
        const successMsg = document.getElementById("purchaseSuccessMessage");
        errorMsg.classList.remove("show");
        successMsg.classList.remove("show");
    }

    function showError(message) {
        const errorMsg = document.getElementById("purchaseErrorMessage");
        errorMsg.textContent = message;
        errorMsg.classList.add("show");
        setTimeout(() => errorMsg.classList.remove("show"), 5000);
    }

    function showSuccess(message) {
        const successMsg = document.getElementById("purchaseSuccessMessage");
        successMsg.textContent = message;
        successMsg.classList.add("show");
    }

    // Payment method selection
    document.querySelectorAll(".payment-method-card").forEach(card => {
        card.addEventListener("click", function() {
            const method = this.dataset.method;
            selectedPaymentMethod = method;
            purchaseState.method = method;

            // Update UI
            document.querySelectorAll(".payment-method-card").forEach(c => c.classList.remove("selected"));
            this.classList.add("selected");
            this.querySelector(".payment-method-radio").checked = true;

            // Show/hide payment options
            document.getElementById("ewalletOptions").classList.toggle("active", method === "ewallet");
            document.getElementById("creditcardForm").classList.toggle("active", method === "creditcard");

            selectedEwallet = null;
            purchaseState.ewallet = null;
            updateSummary();
        });
    });

    window.selectEwallet = function(ewallet) {
        selectedEwallet = ewallet;
        purchaseState.ewallet = ewallet;

        document.querySelectorAll(".ewallet-btn").forEach(btn => btn.classList.remove("active"));
        document.querySelector(`.ewallet-btn[data-ewallet="${ewallet}"]`).classList.add("active");

        updateSummary();
    };

    // Threads input validation
    document.getElementById("threadsAmount").addEventListener("input", function() {
        const amount = parseInt(this.value) || 0;
        if (amount < 100 && amount > 0) {
            showError("Minimum purchase is 100 threads");
            this.value = "";
            return;
        }
        purchaseState.threads = amount;
        updateSummary();
    });

    // Card input formatting
    document.getElementById("cardNumber").addEventListener("input", function() {
        let value = this.value.replace(/\s/g, "").replace(/\D/g, "");
        let formatted = value.replace(/(\d{4})/g, "$1 ").trim();
        this.value = formatted;
    });

    document.getElementById("cardExpiry").addEventListener("input", function() {
        let value = this.value.replace(/\D/g, "");
        if (value.length >= 2) {
            value = value.slice(0, 2) + "/" + value.slice(2, 4);
        }
        this.value = value;
    });

    document.getElementById("cardCVV").addEventListener("input", function() {
        this.value = this.value.replace(/\D/g, "").slice(0, 4);
    });

    function updateSummary() {
        const threadsAmount = purchaseState.threads;
        const method = purchaseState.method;
        const ewallet = purchaseState.ewallet;

        if (threadsAmount > 0 && method) {
            document.getElementById("paymentSummary").style.display = "block";
            document.getElementById("summaryThreads").textContent = threadsAmount;

            let methodText = method === "ewallet" ? (ewallet ? ewallet.toUpperCase() : "E-Wallet") : "Credit Card";
            if (method === "creditcard" && document.getElementById("cardholderName").value) {
                methodText = "Credit Card - " + document.getElementById("cardholderName").value;
            }

            document.getElementById("summaryMethod").textContent = methodText;
            document.getElementById("summaryTotal").textContent = `₱${threadsAmount}.00`;

            // Enable confirm button if valid
            const isValid = validatePaymentForm();
            document.getElementById("confirmPurchaseBtn").disabled = !isValid;
        } else {
            document.getElementById("paymentSummary").style.display = "none";
            document.getElementById("confirmPurchaseBtn").disabled = true;
        }
    }

    document.getElementById("cardholderName").addEventListener("input", updateSummary);

    // E-Wallet phone number input formatting and validation
    const ewalletPhoneInput = document.getElementById("ewalletPhoneNumber");
    if (ewalletPhoneInput) {
        ewalletPhoneInput.addEventListener("input", function() {
            // Only allow numbers
            this.value = this.value.replace(/\D/g, "");
            // Limit to 10 digits
            if (this.value.length > 10) {
                this.value = this.value.slice(0, 10);
            }
            purchaseState.ewalletPhone = this.value;
            updateSummary();
        });
    }

    function validatePaymentForm() {
        const threads = purchaseState.threads;
        const method = purchaseState.method;

        if (threads < 100) return false;
        if (!method) return false;

        if (method === "ewallet") {
            const phoneNum = document.getElementById("ewalletPhoneNumber").value;
            return !!purchaseState.ewallet && phoneNum.length === 10;
        } else if (method === "creditcard") {
            const cardName = document.getElementById("cardholderName").value.trim();
            const cardNum = document.getElementById("cardNumber").value.replace(/\s/g, "");
            const cardExp = document.getElementById("cardExpiry").value;
            const cardCVV = document.getElementById("cardCVV").value;

            return cardName && cardNum.length === 16 && cardExp.length === 5 && cardCVV.length >= 3;
        }

        return false;
    }

    window.confirmThreadsPurchase = async function() {
        const btn = document.getElementById("confirmPurchaseBtn");

        if (!validatePaymentForm()) {
            showError("Please fill in all required fields correctly");
            return;
        }

        // Save values before any modal changes
        const threadsToAdd = purchaseState.threads;
        const paymentMethod = purchaseState.method;
        const phoneNum = document.getElementById("ewalletPhoneNumber").value;

        // If e-wallet selected, show OTP verification instead of proceeding to payment
        if (paymentMethod === "ewallet") {
            closePurchaseThreadsModal();
            showOtpVerificationModal(
                phoneNum,
                threadsToAdd,
                paymentMethod
            );
            return;
        }

        // For credit card, proceed directly to payment processing
        closePurchaseThreadsModal();
        await processPayment(threadsToAdd, paymentMethod);
    };

    window.pendingPayment = {};

    window.showOtpVerificationModal = function(phoneNum, threadsToAdd, paymentMethod) {

        // Convert 9756113912 -> 09756113912
        const formattedPhone = "0" + phoneNum;

        console.log("OTP sent to:", formattedPhone);

        // Save pending payment data
        window.pendingPayment = {
            threadsToAdd,
            paymentMethod
        };

        // Show phone number
        document.getElementById("otpPhoneDisplay").textContent = formattedPhone;

        // Reset OTP input
        document.getElementById("otpInput").value = "";
        document.getElementById("otpErrorMessage").style.display = "none";

        // Disable verify button initially
        document.getElementById("verifyOtpBtn").disabled = true;

        // Show modal
        document.getElementById("otpVerificationModal").style.display = "flex";
    };

    window.verifyOtp = async function() {

        const otp = document.getElementById("otpInput").value;

        if (otp.length !== 6) {
            return;
        }

        // Demo OTP
        // Change this later to backend verification
        if (otp !== "916482") {

            const errorDiv = document.getElementById("otpErrorMessage");

            errorDiv.textContent = "Invalid OTP";
            errorDiv.style.display = "block";

            return;
        }

        // Close OTP modal
        closeOtpModal();

        // Continue payment
        await processPayment(
            window.pendingPayment.threadsToAdd,
            window.pendingPayment.paymentMethod
        );
    };

    window.closeOtpModal = function() {

        document.getElementById("otpVerificationModal").style.display = "none";
    };

    document.getElementById("otpInput").addEventListener("input", function () {

        // numbers only
        this.value = this.value.replace(/\D/g, "");

        const isValid = this.value.length === 6;

        document.getElementById("verifyOtpBtn").disabled = !isValid;
    });

    // Process Payment Function (shared by both OTP-verified e-wallet and credit card payments)
    async function processPayment(threadsToAdd, paymentMethod) {
        showPaymentProcessingModal();

        try {
            const userId = window.currentUserId;

            if (!userId) {
                showPaymentError("User ID not found");
                return;
            }

            let paymentDetails = {
                userId: userId,
                threads: threadsToAdd,
                paymentMethod: paymentMethod
            };

            // E-wallet details
            if (paymentMethod === "ewallet") {
                const phoneNum = document.getElementById("ewalletPhoneNumber").value;

                paymentDetails.ewalletProvider = purchaseState.ewallet;
                paymentDetails.ewalletNumber = "0" + phoneNum;
            }

            // Credit card details
            else if (paymentMethod === "creditcard") {
                const cardNum = document.getElementById("cardNumber").value.replace(/\s/g, "");

                paymentDetails.cardholderName = document.getElementById("cardholderName").value;
                paymentDetails.cardLast4 = cardNum.slice(-4);
            }

            // Simulate payment delay
            await new Promise(resolve => setTimeout(resolve, 5000));

            console.log({
                userId: userId,
                threadsToAdd: threadsToAdd,
                paymentMethod: paymentMethod
            });

            // Call backend
            const response = await fetch(`/api/threads/add`, {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify({
                    userId: userId,
                    threadsToAdd: threadsToAdd,
                    paymentMethod: paymentMethod
                })
            });

            if (!response.ok) {
                throw new Error("Failed to add threads");
            }

            const result = await response.json();

            if (result.success) {
                showPaymentSuccess(threadsToAdd, threadsToAdd);
            } else {
                showPaymentError(result.message || "Failed to add threads");
            }

        } catch (err) {
            console.error("Purchase error:", err);
            showPaymentError("Payment processing failed. Please try again.");
        }
    }

